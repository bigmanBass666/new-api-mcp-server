# ============================================================
# new-api-mcp-server Docker Compose — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- New API secrets (generate with: openssl rand -base64 32) ---
SESSION_SECRET=change-me-to-a-random-string
CRYPTO_SECRET=change-me-to-a-different-random-string

# --- MCP server API keys ---
# Admin API key (from New API user's access_token, required for admin tools)
NEW_API_SYSTEM_KEY=your-admin-access-token

# Relay API key (regular New API user token, for model relay tools)
NEW_API_KEY=your-relay-token

# HTTP auth token for the MCP server endpoint (generate a random string)
# This protects your MCP server from unauthorized access
MCP_HTTP_AUTH_TOKEN=change-me-to-a-random-token

# --- Optional ---
# Comma-separated list of relay groups to enable (empty = all enabled)
MCP_RELAY_ENABLED_GROUPS=

# Log level (debug, info, warn, error)
MCP_LOG_LEVEL=info